<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Quản lí thanh toán</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="icon" type="image/png" href="https://hcmute.edu.vn/Resources/Imagephoto/logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f8f9fa;
      overflow-x: hidden;
    }
    
    .sidebar {
      height: 100vh;
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      color: #1f2937;
      position: fixed;
      width: 220px;
      box-shadow: 2px 0 20px rgba(0, 0, 0, 0.1);
      border-right: 1px solid #e5e7eb;
    }
    
    .sidebar-header {
      padding: 25px 15px 30px 15px;
      text-align: center;
      border-bottom: 1px solid rgba(31, 41, 55, 0.1);
      background: rgba(248, 250, 252, 0.5);
      overflow: visible;
      min-height: 180px;
    }
    
    .logo-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-bottom: 25px;
      overflow: visible;
    }
    
    .logo-spkt {
      width: 110px;
      height: auto;
      min-height: 110px;
      border-radius: 18px;
      background: transparent;
      padding: 5px;
      filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
      transition: all 0.3s ease;
      display: block;
      overflow: visible;
    }
    
    .logo-spkt:hover {
      transform: translateY(-4px) scale(1.05);
      filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.25));
    }
    
    .logo-iotvision {
      width: 190px;
      height: auto;
      border-radius: 0;
      background: transparent;
      padding: 0;
      filter: drop-shadow(0 3px 10px rgba(0, 0, 0, 0.1));
      transition: all 0.3s ease;
      display: block;
    }
    
    .logo-iotvision:hover {
      transform: translateY(-3px) scale(1.03);
      filter: drop-shadow(0 6px 15px rgba(0, 0, 0, 0.2));
    }
    
    .sidebar-header h4 {
      margin: 0;
      font-size: 18px;
      font-weight: 700;
      color: #1f2937;
      line-height: 1.4;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    }
    
    .sidebar-nav {
      padding: 15px 0;
    }
    
    .sidebar-nav a {
      display: block;
      color: #6b7280;
      padding: 12px 15px;
      text-decoration: none;
      transition: all 0.3s;
      border-left: 3px solid transparent;
      font-size: 14px;
      font-weight: 500;
    }
    
    .sidebar-nav a:hover,
    .sidebar-nav a.active {
      background-color: rgba(59, 130, 246, 0.08);
      color: #1e40af;
      border-left-color: #3b82f6;
      transform: translateX(3px);
    }
    
    .sidebar-nav i {
      width: 18px;
      margin-right: 10px;
      color: #9ca3af;
    }
    
    .sidebar-nav a:hover i,
    .sidebar-nav a.active i {
      color: #3b82f6;
    }
    
    .logout-btn {
      position: absolute;
      bottom: 15px;
      left: 15px;
      right: 15px;
      background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
      color: white;
      border: none;
      padding: 12px;
      border-radius: 10px;
      text-decoration: none;
      text-align: center;
      font-size: 14px;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: 0 3px 10px rgba(239, 68, 68, 0.3);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }
    
    .logout-btn:hover {
      background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(239, 68, 68, 0.4);
    }
    
    .main-content {
      margin-left: 220px;
      padding: 15px;
      height: 100vh;
      overflow-y: auto;
      overflow-x: hidden;
      box-sizing: border-box;
    }
    
    .page-header {
      background: white;
      padding: 12px 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      margin-bottom: 12px;
    }
    
    .page-header h1 {
      margin: 0;
      color: #1f2937;
      font-size: 20px;
    }
    
    .page-header .subtitle {
      color: #6b7280;
      font-size: 14px;
      margin-top: 5px;
    }
    
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 15px;
      margin-bottom: 15px;
    }
    
    .stat-card {
      background: white;
      padding: 15px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      border-left: 4px solid;
      transition: all 0.3s ease;
    }
    
    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    }
    
    .stat-card.total { border-left-color: #3b82f6; }
    .stat-card.paid { border-left-color: #10b981; }
    .stat-card.unpaid { border-left-color: #ef4444; }
    .stat-card.revenue { border-left-color: #8b5cf6; }
    
    .stat-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    
    .stat-title {
      font-size: 13px;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .stat-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      color: white;
    }
    
    .stat-card.total .stat-icon { background: #3b82f6; }
    .stat-card.paid .stat-icon { background: #10b981; }
    .stat-card.unpaid .stat-icon { background: #ef4444; }
    .stat-card.revenue .stat-icon { background: #8b5cf6; }
    
    .stat-value {
      font-size: 24px;
      font-weight: 700;
      color: #1f2937;
      margin-bottom: 4px;
    }
    
    .stat-subtitle {
      font-size: 11px;
      color: #9ca3af;
    }
    
    .payments-table {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      overflow: hidden;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    
    .table-header {
      background: #f8fafc;
      padding: 15px 20px;
      border-bottom: 1px solid #e5e7eb;
      flex-shrink: 0;
    }
    
    .table-title {
      font-size: 16px;
      font-weight: 600;
      color: #1f2937;
      margin: 0;
    }
    
    .table-responsive {
      flex: 1;
      overflow-y: auto;
      min-height: 0;
    }
    
    .table {
      margin: 0;
    }
    
    .table thead th {
      background: #f8fafc;
      border-bottom: 2px solid #e5e7eb;
      font-weight: 600;
      color: #374151;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 12px 10px;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    
    .table tbody td {
      padding: 12px 10px;
      vertical-align: middle;
      border-bottom: 1px solid #f3f4f6;
      font-size: 13px;
    }
    
    .table tbody tr:hover {
      background-color: #f9fafb;
    }
    
    .room-info {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .room-number {
      font-weight: 600;
      color: #1f2937;
      font-size: 15px;
    }
    
    .room-phone {
      color: #6b7280;
      font-size: 13px;
    }
    
    .status-badge {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .status-paid {
      background: #d1fae5;
      color: #065f46;
    }
    
    .status-unpaid {
      background: #fee2e2;
      color: #991b1b;
    }
    
    .status-vacant {
      background: #f3f4f6;
      color: #6b7280;
    }
    
    .payment-details {
      text-align: right;
    }
    
    .payment-amount {
      font-weight: 600;
      color: #1f2937;
      font-size: 15px;
    }
    
    .payment-breakdown {
      font-size: 12px;
      color: #6b7280;
      margin-top: 2px;
    }
    
    .payment-date {
      font-size: 13px;
      color: #6b7280;
    }
    
    .due-date {
      font-size: 13px;
      color: #ef4444;
      font-weight: 500;
    }
    
    .btn-mark-paid {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border: none;
      color: white;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
    }
    
    .btn-mark-paid:hover {
      background: linear-gradient(135deg, #059669 0%, #047857 100%);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
      color: white;
    }
    
    .btn-view-details {
      background: transparent;
      border: 1px solid #d1d5db;
      color: #6b7280;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 12px;
      transition: all 0.3s;
    }
    
    .btn-view-details:hover {
      border-color: #3b82f6;
      color: #3b82f6;
      background: rgba(59, 130, 246, 0.05);
    }
    
    .action-buttons {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
    }
    
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #6b7280;
    }
    
    .empty-state i {
      font-size: 48px;
      margin-bottom: 20px;
      color: #d1d5db;
    }
    
    .empty-state h3 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 10px;
      color: #374151;
    }
    
    .empty-state p {
      font-size: 14px;
      margin: 0;
    }
    
    /* Main content layout for viewport fit */
    .content-wrapper {
      display: flex;
      flex-direction: column;
      height: calc(100vh - 30px);
      gap: 12px;
    }
    
    .content-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
      gap: 15px;
    }

    /* Alert Styles */
    .alert {
      border: none;
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 12px;
      font-weight: 500;
    }
    
    .alert-success {
      background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
      color: #065f46;
      border-left: 4px solid #10b981;
    }
    
    .alert-danger {
      background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
      color: #991b1b;
      border-left: 4px solid #ef4444;
    }
  </style>
</head>
<body>
  <!-- Sidebar -->
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="logo-container">
        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b9/Logo_Tr%C6%B0%E1%BB%9Dng_%C4%90%E1%BA%A1i_H%E1%BB%8Dc_S%C6%B0_Ph%E1%BA%A1m_K%E1%BB%B9_Thu%E1%BA%ADt_TP_H%E1%BB%93_Ch%C3%AD_Minh.png" alt="SPKT Logo" class="logo-spkt">
        <img src="https://iotvision.vn/images/IoTVision-Logo.png" alt="IoTVision Logo" class="logo-iotvision">
      </div>
      <h4>Building Management</h4>
    </div>
    
    <div class="sidebar-nav">
      <a href="/dashboard">
        <i class="fas fa-home"></i>
        Quản lý phòng
      </a>
      <a href="/statistic">
        <i class="fas fa-chart-bar"></i>
        Biểu đồ
      </a>
      <a href="/payments" class="active">
        <i class="fas fa-money-bill-wave"></i>
        Thanh toán
      </a>
      <a href="/settings">
        <i class="fas fa-cog"></i>
        Cài đặt
      </a>
    </div>
    
    <a href="/logout" class="logout-btn">
      <i class="fas fa-sign-out-alt"></i>
      Đăng xuất
    </a>
  </div>

  <!-- Main Content -->
  <div class="main-content">
    <div class="content-wrapper">
      <!-- Page Header -->
      <div class="page-header">
        <h1><i class="fas fa-money-bill-wave"></i> Quản lí thanh toán tháng <%= currentMonth %></h1>
      </div>

      <!-- Success/Error Messages -->
      <% if (success) { %>
        <div class="alert alert-success">
          <i class="fas fa-check-circle"></i> <%= success %>
        </div>
      <% } %>
      
      <% if (error) { %>
        <div class="alert alert-danger">
          <i class="fas fa-exclamation-circle"></i> <%= error %>
        </div>
      <% } %>

      <div class="content-body">
        <!-- Statistics Grid -->
        <div class="stats-grid">
          <div class="stat-card total">
            <div class="stat-header">
              <div class="stat-title">Tổng phòng</div>
              <div class="stat-icon">
                <i class="fas fa-door-open"></i>
              </div>
            </div>
            <div class="stat-value"><%= stats.totalRooms %></div>
            <div class="stat-subtitle">Phòng đang có người thuê</div>
          </div>
          
          <div class="stat-card paid">
            <div class="stat-header">
              <div class="stat-title">Đã thanh toán</div>
              <div class="stat-icon">
                <i class="fas fa-check-circle"></i>
              </div>
            </div>
            <div class="stat-value"><%= stats.paidRooms %></div>
            <div class="stat-subtitle">Tỷ lệ: <%= stats.paymentRate %>%</div>
          </div>
          
          <div class="stat-card unpaid">
            <div class="stat-header">
              <div class="stat-title">Chưa thanh toán</div>
              <div class="stat-icon">
                <i class="fas fa-exclamation-triangle"></i>
              </div>
            </div>
            <div class="stat-value"><%= stats.unpaidRooms %></div>
            <div class="stat-subtitle">Cần thu tiền</div>
          </div>
          
          <div class="stat-card revenue">
            <div class="stat-header">
              <div class="stat-title">Doanh thu</div>
              <div class="stat-icon">
                <i class="fas fa-coins"></i>
              </div>
            </div>
            <div class="stat-value"><%= (stats.totalRevenue / 1000000).toFixed(1) %>M</div>
            <div class="stat-subtitle">Đã thu: <%= (stats.totalRevenue / 1000000).toFixed(1) %>M | Chờ: <%= (stats.pendingRevenue / 1000000).toFixed(1) %>M</div>
          </div>
        </div>

        <!-- Payments Table -->
        <div class="payments-table">
      <div class="table-header">
        <h3 class="table-title">
          <i class="fas fa-list"></i> Danh sách thanh toán tháng <%= currentMonth %>/<%= currentYear %>
        </h3>
      </div>
      
      <div class="table-responsive">
        <% if (rooms.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <h3>Chưa có dữ liệu</h3>
            <p>Không có phòng nào để hiển thị</p>
          </div>
        <% } else { %>
          <table class="table" id="paymentsTable">
            <thead>
              <tr>
                <th>Phòng</th>
                <th>Trạng thái</th>
                <th>Chi tiết thanh toán</th>
                <th>Ngày thanh toán</th>
                <th>Hạn thanh toán</th>
                <th>Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <% rooms.forEach(room => { %>
                <tr>
                  <td>
                    <div class="room-info">
                      <div>
                        <div class="room-number">Phòng <%= room.roomNumber %></div>
                        <% if (room.phoneNumber) { %>
                          <div class="room-phone"><i class="fas fa-phone"></i> <%= room.phoneNumber %></div>
                        <% } %>
                      </div>
                    </div>
                  </td>
                  <td>
                    <% if (room.status === 'vacant') { %>
                      <span class="status-badge status-vacant">Trống</span>
                    <% } else if (room.payment.isPaid) { %>
                      <span class="status-badge status-paid">Đã thanh toán</span>
                    <% } else { %>
                      <span class="status-badge status-unpaid">Chưa thanh toán</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (room.status !== 'vacant') { %>
                      <div class="payment-details">
                        <div class="payment-amount"><%= (room.payment.totalCost).toLocaleString('vi-VN') %>đ</div>
                        <div class="payment-breakdown">
                          Phòng: <%= (room.payment.roomFee).toLocaleString('vi-VN') %>đ<br>
                          Điện: <%= room.payment.electricUsage %>kWh - <%= (room.payment.electricCost).toLocaleString('vi-VN') %>đ<br>
                          Nước: <%= room.payment.waterUsage %>m³ - <%= (room.payment.waterCost).toLocaleString('vi-VN') %>đ
                        </div>
                      </div>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (room.status !== 'vacant' && room.payment.isPaid && room.payment.paymentDate) { %>
                      <div class="payment-date">
                        <i class="fas fa-calendar-check text-success"></i>
                        <%= room.payment.paymentDate.toLocaleDateString('vi-VN') %>
                      </div>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (room.status !== 'vacant') { %>
                      <div class="due-date">
                        <i class="fas fa-calendar-times"></i>
                        <%= room.payment.dueDate.toLocaleDateString('vi-VN') %>
                      </div>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="action-buttons">
                      <% if (room.status !== 'vacant') { %>
                        <% if (!room.payment.isPaid) { %>
                          <form method="POST" action="/mark-payment" style="display: inline;">
                            <input type="hidden" name="roomId" value="<%= room.id %>">
                            <input type="hidden" name="month" value="<%= currentMonthKey %>">
                            <button type="submit" class="btn-mark-paid" onclick="return confirm('Xác nhận đánh dấu phòng <%= room.roomNumber %> đã thanh toán?')">
                              <i class="fas fa-check"></i> Đã thanh toán
                            </button>
                          </form>
                        <% } %>
                        <button class="btn-view-details" onclick="viewPaymentDetails('<%= room.id %>')">
                          <i class="fas fa-eye"></i> Chi tiết
                        </button>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    function viewPaymentDetails(roomId) {
      alert('Chi tiết thanh toán cho phòng ' + roomId + ' - Tính năng sẽ được phát triển sau');
    }
  </script>
</body>
</html>
