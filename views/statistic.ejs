  // Function to create Ant Design month picker
  function createMonthPicker(containerId, hiddenInputId, onChange) {
    const container = document.getElementById(containerId);
    const hiddenInput = document.getElementById(hiddenInputId);
    
    if (!container || !hiddenInput) {
      console.log(`❌ Container ${containerId} or hidden input ${hiddenInputId} not found`);
      return;
    }
    
    const root = createRoot(container);
    
    // Get initial value from hidden input
    let initialValue = null;
    if (hiddenInput.value && hiddenInput.value.trim()) {
      try {
        initialValue = dayjs(hiddenInput.value, 'YYYY-MM');
      } catch (e) {
        console.log(`⚠️ Invalid date format in ${hiddenInputId}:`, hiddenInput.value);
      }
    }
    
    const monthPicker = h(ConfigProvider, {
      locale: vietnameseLocale
    }, h(DatePicker, {
      picker: 'month',
      placeholder: 'Chọn tháng',
      format: 'MM/YYYY',
      value: initialValue,
      onChange: (date, dateString) => {
        console.log(`📅 ${containerId} changed:`, dateString, date?.format('YYYY-MM'));
        if (date) {
          hiddenInput.value = date.format('YYYY-MM');
        } else {
          hiddenInput.value = '';
        }
        if (onChange) {
          onChange(date, dateString);
        }
      },
      style: { width: '100%', height: '36px' }
    }));
    
    root.render(monthPicker);
    console.log(`✅ Created month picker for ${containerId}`);
    
    return root;
  }
  
  // Function to create Ant Design month range picker
  function createMonthRangePicker(containerId, fromHiddenId, toHiddenId, onChange) {
    const container = document.getElementById(containerId);
    const fromHidden = document.getElementById(fromHiddenId);
    const toHidden = document.getElementById(toHiddenId);
    
    if (!container || !fromHidden || !toHidden) {
      console.log(`❌ Container ${containerId} or hidden inputs not found`);
      return;
    }
    
    const root = createRoot(container);
    
    // Get initial values from hidden inputs
    let initialValue = null;
    if (fromHidden.value && toHidden.value && fromHidden.value.trim() && toHidden.value.trim()) {
      try {
        const fromDate = dayjs(fromHidden.value, 'YYYY-MM');
        const toDate = dayjs(toHidden.value, 'YYYY-MM');
        initialValue = [fromDate, toDate];
      } catch (e) {
        console.log(`⚠️ Invalid date format:`, fromHidden.value, toHidden.value);
      }
    }
    
    const rangePicker = h(ConfigProvider, {
      locale: vietnameseLocale
    }, h(RangePicker, {
      picker: 'month',
      placeholder: ['Từ tháng', 'Đến tháng'],
      format: 'MM/YYYY',
      value: initialValue,
      onChange: (dates, dateStrings) => {
        console.log(`📅 ${containerId} range changed:`, dateStrings);
        if (dates && dates.length === 2) {
          fromHidden.value = dates[0].format('YYYY-MM');
          toHidden.value = dates[1].format('YYYY-MM');
        } else {
          fromHidden.value = '';
          toHidden.value = '';
        }
        if (onChange) {
          onChange(dates, dateStrings);
        }
      },
      style: { width: '100%', height: '36px' }
    }));
    
    root.render(rangePicker);
    console.log(`✅ Created month range picker for ${containerId}`);
    
    return root;
  }
  
