<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Biểu đồ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="icon" type="image/png" href="https://hcmute.edu.vn/Resources/Imagephoto/logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Ant Design CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/antd@5.12.8/dist/reset.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/antd@5.12.8/dist/antd.min.css">
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f8f9fa;
      overflow-x: hidden;
    }
    
    .sidebar {
      height: 100vh;
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
      color: #1f2937;
      position: fixed;
      width: 220px;
      box-shadow: 2px 0 20px rgba(0, 0, 0, 0.1);
      border-right: 1px solid #e5e7eb;
    }
    
    .sidebar-header {
      padding: 25px 15px 30px 15px;
      text-align: center;
      border-bottom: 1px solid rgba(31, 41, 55, 0.1);
      background: rgba(248, 250, 252, 0.5);
      overflow: visible;
      min-height: 180px;
    }
    
    .logo-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-bottom: 25px;
      overflow: visible;
    }
    
    .logo-spkt {
      width: 110px;
      height: auto;
      min-height: 110px;
      border-radius: 18px;
      background: transparent;
      padding: 5px;
      filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
      transition: all 0.3s ease;
      display: block;
      overflow: visible;
    }
    
    .logo-spkt:hover {
      transform: translateY(-4px) scale(1.05);
      filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.25));
    }
    
    .logo-iotvision {
      width: 190px;
      height: auto;
      border-radius: 0;
      background: transparent;
      padding: 0;
      filter: drop-shadow(0 3px 10px rgba(0, 0, 0, 0.1));
      transition: all 0.3s ease;
      display: block;
    }
    
    .logo-iotvision:hover {
      transform: translateY(-3px) scale(1.03);
      filter: drop-shadow(0 6px 15px rgba(0, 0, 0, 0.2));
    }
    
    .sidebar-header h4 {
      margin: 0;
      font-size: 18px;
      font-weight: 700;
      color: #1f2937;
      line-height: 1.4;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    }
    
    .sidebar-nav {
      padding: 15px 0;
    }
    
    .sidebar-nav a {
      display: block;
      color: #6b7280;
      padding: 12px 15px;
      text-decoration: none;
      transition: all 0.3s;
      border-left: 3px solid transparent;
      font-size: 14px;
      font-weight: 500;
    }
    
    .sidebar-nav a:hover,
    .sidebar-nav a.active {
      background-color: rgba(59, 130, 246, 0.08);
      color: #1e40af;
      border-left-color: #3b82f6;
      transform: translateX(3px);
    }
    
    .sidebar-nav i {
      width: 18px;
      margin-right: 10px;
      color: #9ca3af;
    }
    
    .sidebar-nav a:hover i,
    .sidebar-nav a.active i {
      color: #3b82f6;
    }
    
    .logout-btn {
      position: absolute;
      bottom: 15px;
      left: 15px;
      right: 15px;
      background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
      color: white;
      border: none;
      padding: 12px;
      border-radius: 10px;
      text-decoration: none;
      text-align: center;
      font-size: 14px;
      font-weight: 600;
      transition: all 0.3s;
      box-shadow: 0 3px 10px rgba(239, 68, 68, 0.3);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }
    
    .logout-btn:hover {
      background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(239, 68, 68, 0.4);
    }
    
    .main-content {
      margin-left: 220px;
      padding: 15px;
      height: 100vh;
      overflow: hidden;
      box-sizing: border-box;
    }
    
    .page-header {
      background: white;
      padding: 12px 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      margin-bottom: 12px;
    }
    
    .page-header h1 {
      margin: 0;
      color: #1f2937;
      font-size: 20px;
    }
    
    .filter-section {
      margin-bottom: 12px;
    }
    
    .filter-card {
      background: white;
      padding: 10px 15px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }
    
    .filter-form {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    
    .form-group {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .form-label {
      margin: 0;
      font-weight: 600;
      color: #374151;
      white-space: nowrap;
      font-size: 14px;
    }
    
    .form-label i {
      color: #6b7280;
      margin-right: 5px;
    }
    
    .form-select {
      min-width: 180px;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      padding: 6px 10px;
      font-size: 13px;
    }
    
    .form-select:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
    }
    
    .charts-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      height: calc(100vh - 140px);
      padding-bottom: 15px;
    }
    
    .chart-card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      height: calc((100vh - 170px) / 2);
    }
    
    .chart-header {
      background: white;
      padding: 10px 16px;
      border-bottom: 1px solid #e5e7eb;
      flex-shrink: 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .chart-title h5 {
      margin: 0;
      color: #1f2937;
      font-size: 15px;
      font-weight: 600;
    }
    
    .chart-title i {
      margin-right: 8px;
    }
    
    .chart-controls {
      margin: 0;
    }
    
    .chart-form {
      display: flex;
      align-items: center;
      gap: 20px;
      font-size: 14px;
    }
    
    .view-type-selector {
      display: flex;
      gap: 15px;
      align-items: center;
    }
    
    .form-check {
      margin: 0;
      display: flex;
      align-items: center;
    }
    
    .form-check-input {
      margin-right: 6px;
    }
    
    .form-check-label {
      font-weight: 500;
      color: #374151;
      font-size: 14px;
    }
    
    .date-range-selector {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .range-label {
      font-weight: 500;
      color: #374151;
      margin: 0;
      white-space: nowrap;
      font-size: 14px;
    }
    
    .form-control {
      border: 1px solid #d1d5db;
      border-radius: 6px;
      padding: 6px 12px;
      font-size: 14px;
      min-width: 130px;
      height: 36px;
    }
    
    .form-control:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
    
    .month-picker {
      width: 120px;
      text-align: center;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
      border: none;
      color: white;
      padding: 8px 16px;
      border-radius: 6px;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.3s;
      height: 36px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    
    .btn-primary:hover {
      background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }
    
    .chart-body {
      padding: 15px;
      flex: 1;
      min-height: 320px;
      position: relative;
    }
    
    .chart-canvas {
      width: 100% !important;
      height: 100% !important;
    }
    
    /* Responsive Design */
    @media (max-width: 1024px) {
      .charts-grid {
        grid-template-columns: 1fr;
        height: auto;
      }
      
      .chart-card {
        height: 450px;
      }
      
      .chart-body {
        min-height: 380px;
      }
    }
    
    @media (max-width: 768px) {
      .main-content {
        margin-left: 0;
        padding: 10px;
      }
      
      .filter-form {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
      }
      
      .form-group {
        justify-content: space-between;
      }
      
      .chart-header {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
        padding: 15px;
      }
      
      .chart-form {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
      }
      
      .view-type-selector {
        justify-content: center;
      }
      
      .date-range-selector {
        flex-wrap: wrap;
        justify-content: center;
      }
      
      .charts-grid {
        height: auto;
      }
      
      .chart-card {
        height: 380px;
      }
      
      .chart-body {
        min-height: 320px;
      }
      
      .form-control {
        min-width: 100px;
      }
    }
    
    /* Chart container sizing */
    .chart-container {
      position: relative;
      height: 100%;
      width: 100%;
      min-height: 300px;
    }
    
    /* Vietnamese Month Picker Styling */
    .month-picker-vn {
      width: 130px !important;
      height: 36px !important;
      border-radius: 6px !important;
      border: 1px solid #d1d5db !important;
      font-size: 14px !important;
      background-color: white !important;
      color: #374151 !important;
    }
    
    .month-picker-vn:hover {
      border-color: #3b82f6 !important;
    }
    
    .month-picker-vn:focus {
      border-color: #3b82f6 !important;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1) !important;
      outline: none !important;
    }
    
    /* Force Vietnamese locale for month picker */
    .month-picker-vn::-webkit-calendar-picker-indicator {
      cursor: pointer;
      opacity: 0.8;
    }
    
    .month-picker-vn::-webkit-calendar-picker-indicator:hover {
      opacity: 1;
    }
    
    /* Ant Design Month Picker Styling */
    .antd-month-picker {
      width: 130px;
      height: 36px;
    }
    
    .antd-month-picker .ant-picker {
      width: 100%;
      height: 100%;
      border-radius: 6px;
      border: 1px solid #d1d5db;
      font-size: 14px;
    }
    
    .antd-month-picker .ant-picker:hover {
      border-color: #3b82f6;
    }
    
    .antd-month-picker .ant-picker-focused {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
    
    .antd-month-picker .ant-picker-input > input {
      font-size: 14px;
      color: #374151;
    }
    
    /* Ant Design Range Picker Styling */
    .antd-range-picker {
      width: 280px;
      height: 36px;
    }
    
    .antd-range-picker .ant-picker {
      width: 100%;
      height: 100%;
      border-radius: 6px;
      border: 1px solid #d1d5db;
      font-size: 14px;
    }
    
    .antd-range-picker .ant-picker:hover {
      border-color: #3b82f6;
    }
    
    .antd-range-picker .ant-picker-focused {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
    
    .antd-range-picker .ant-picker-input > input {
      font-size: 14px;
      color: #374151;
    }
    
    .antd-range-picker .ant-picker-range-separator {
      color: #6b7280;
    }
  </style>
</head>
<body>
  <!-- Sidebar -->
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="logo-container">
        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b9/Logo_Tr%C6%B0%E1%BB%9Dng_%C4%90%E1%BA%A1i_H%E1%BB%8Dc_S%C6%B0_Ph%E1%BA%A1m_K%E1%BB%B9_Thu%E1%BA%ADt_TP_H%E1%BB%93_Ch%C3%AD_Minh.png" alt="SPKT Logo" class="logo-spkt">
        <img src="https://iotvision.vn/images/IoTVision-Logo.png" alt="IoTVision Logo" class="logo-iotvision">
      </div>
      <h4>Building Management</h4>
    </div>
    
    <div class="sidebar-nav">
      <a href="/dashboard">
        <i class="fas fa-home"></i>
        Quản lý phòng
      </a>
      <a href="/statistic" class="active">
        <i class="fas fa-chart-bar"></i>
        Biểu đồ
      </a>
      <a href="/readings">
        <i class="fas fa-list-alt"></i>
        Số liệu
      </a>
      <a href="/settings">
        <i class="fas fa-cog"></i>
        Cài đặt
      </a>
    </div>
    
    <a href="/logout" class="logout-btn">
      <i class="fas fa-sign-out-alt"></i>
      Đăng xuất
    </a>
  </div>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Page Header -->
    <div class="page-header">
      <h1><i class="fas fa-chart-bar"></i> Biểu đồ thống kê</h1>
    </div>

    <!-- Filter Section -->
    <div class="filter-section">
      <div class="filter-card">
        <form class="filter-form" action="/statistic" method="GET" id="roomFilterForm">
          <div class="form-group">
            <label class="form-label">
              <i class="fas fa-door-open"></i>
              Chọn phòng:
            </label>
            <select name="roomId" class="form-select" onchange="document.getElementById('roomFilterForm').submit()">
              <option value="">Tất cả phòng</option>
              <% if (typeof roomList !== 'undefined' && Array.isArray(roomList)) { %>
                <% roomList.forEach(room => { %>
                  <option value="<%= room %>" <%= (typeof selectedRoom !== 'undefined' && selectedRoom === room) ? 'selected' : '' %>>Phòng <%= room %></option>
                <% }); %>
              <% } %>
            </select>
          </div>
        </form>
      </div>
    </div>

    <!-- Charts Grid -->
    <div class="charts-grid">
      <!-- Electric Chart -->
      <div class="chart-card">
        <div class="chart-header">
          <div class="chart-title">
            <h5><i class="fas fa-bolt"></i> Biểu đồ điện</h5>
          </div>
          <div class="chart-controls">
            <form class="chart-form" action="/statistic" method="GET" id="electricForm">
              <!-- Hidden fields to preserve other parameters -->
              <input type="hidden" name="roomId" value="<%= selectedRoom || '' %>">
              <input type="hidden" name="fromWater" value="<%= fromWater || '' %>">
              <input type="hidden" name="toWater" value="<%= toWater || '' %>">
              <input type="hidden" name="viewTypeWater" value="<%= viewTypeWater || 'day' %>">
              
              <div class="view-type-selector">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="viewTypeElectric" value="day" id="electricDay" <%= (viewTypeElectric || 'day') === 'day' ? 'checked' : '' %> onchange="handleElectricViewChange()">
                  <label class="form-check-label" for="electricDay">Ngày</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="viewTypeElectric" value="month" id="electricMonth" <%= viewTypeElectric === 'month' ? 'checked' : '' %> onchange="handleElectricViewChange()">
                  <label class="form-check-label" for="electricMonth">Tháng</label>
                </div>
              </div>
              
              <div class="date-range-selector">
                <% if ((viewTypeElectric || 'day') === 'day') { %>
                  <div id="electricDateRangePicker" class="antd-range-picker"></div>
                  <input type="hidden" name="fromElectric" id="fromElectricDateHidden" value="<%= fromElectric || '' %>">
                  <input type="hidden" name="toElectric" id="toElectricDateHidden" value="<%= toElectric || '' %>">
                <% } else { %>
                  <div id="electricRangePicker" class="antd-range-picker"></div>
                  <input type="hidden" name="fromMonthElectric" id="fromElectricHidden" value="<%= fromYearElectric && fromMonthElectric ? fromYearElectric + '-' + String(fromMonthElectric).padStart(2, '0') : '' %>">
                  <input type="hidden" name="toMonthElectric" id="toElectricHidden" value="<%= toYearElectric && toMonthElectric ? toYearElectric + '-' + String(toMonthElectric).padStart(2, '0') : '' %>">
                <% } %>
              </div>
            </form>
          </div>
        </div>
        <div class="chart-body">
          <div class="chart-container">
            <canvas id="electricChart" class="chart-canvas"></canvas>
          </div>
        </div>
      </div>

      <!-- Water Chart -->
      <div class="chart-card">
        <div class="chart-header">
          <div class="chart-title">
            <h5>
              <i class="fas fa-tint" style="color: #06b6d4;"></i>
              Biểu đồ tiêu thụ nước
            </h5>
          </div>
          <div class="chart-controls">
            <form class="chart-form" action="/statistic" method="GET" id="waterForm">
              <!-- Hidden fields to preserve other parameters -->
              <input type="hidden" name="roomId" value="<%= selectedRoom || '' %>">
              <input type="hidden" name="fromElectric" value="<%= fromElectric || '' %>">
              <input type="hidden" name="toElectric" value="<%= toElectric || '' %>">
              <input type="hidden" name="viewTypeElectric" value="<%= viewTypeElectric || 'day' %>">
              
              <div class="view-type-selector">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="viewTypeWater" value="day" id="waterDay" <%= (viewTypeWater || 'day') === 'day' ? 'checked' : '' %> onchange="handleWaterViewChange()">
                  <label class="form-check-label" for="waterDay">Ngày</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="viewTypeWater" value="month" id="waterMonth" <%= viewTypeWater === 'month' ? 'checked' : '' %> onchange="handleWaterViewChange()">
                  <label class="form-check-label" for="waterMonth">Tháng</label>
                </div>
              </div>
              
              <div class="date-range-selector">
                <% if ((viewTypeWater || 'day') === 'day') { %>
                  <div id="waterDateRangePicker" class="antd-range-picker"></div>
                  <input type="hidden" name="fromWater" id="fromWaterDateHidden" value="<%= fromWater || '' %>">
                  <input type="hidden" name="toWater" id="toWaterDateHidden" value="<%= toWater || '' %>">
                <% } else { %>
                  <div id="waterRangePicker" class="antd-range-picker"></div>
                  <input type="hidden" name="fromMonthWater" id="fromWaterHidden" value="<%= fromYearWater && fromMonthWater ? fromYearWater + '-' + String(fromMonthWater).padStart(2, '0') : '' %>">
                  <input type="hidden" name="toMonthWater" id="toWaterHidden" value="<%= toYearWater && toMonthWater ? toYearWater + '-' + String(toMonthWater).padStart(2, '0') : '' %>">
                <% } %>
              </div>
            </form>
          </div>
        </div>
        <div class="chart-body">
          <div class="chart-container">
            <canvas id="waterChart" class="chart-canvas"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- React, ReactDOM, dayjs and Ant Design JS -->
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dayjs@1.11.10/dayjs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dayjs@1.11.10/locale/vi.js"></script>
<script src="https://cdn.jsdelivr.net/npm/antd@5.12.8/dist/antd.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<script>
  const waterHistory = JSON.parse('<%- JSON.stringify(waterHistory || {}) %>');
  const electricHistory = JSON.parse('<%- JSON.stringify(electricHistory || {}) %>');

  // Debug logs để kiểm tra dữ liệu
  console.log('🔍 Debug - Raw data from server:');
  console.log('💧 waterHistory:', waterHistory);
  console.log('⚡ electricHistory:', electricHistory);
  console.log('📊 Server date ranges:');
  console.log('⚡ Electric range: <%= fromElectric %> to <%= toElectric %>');
  console.log('💧 Water range: <%= fromWater %> to <%= toWater %>');

  // Hàm tạo 9 tháng gần nhất
  function getLast9Months() {
    const months = [];
    const today = new Date();
    for (let i = 8; i >= 0; i--) {
      const d = new Date(today);
      d.setMonth(d.getMonth() - i);
      months.push({
        month: d.getMonth() + 1,
        year: d.getFullYear(),
        monthYear: `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
      });
    }
    return months;
  }

  // Handler functions cho radio button changes - ĐỊNH NGHĨA SỚM TRƯỚC KHI HTML SỬ DỤNG
  window.handleElectricViewChange = function() {
    console.log('⚡ Electric view change triggered');
    
    // Delay nhỏ để đảm bảo DOM đã update
    setTimeout(() => {
      const selectedValue = document.querySelector('input[name="viewTypeElectric"]:checked').value;
      console.log('⚡ Electric view changed to:', selectedValue);
      
      if (selectedValue === 'month') {
        // Set ngay lập tức giá trị 9 tháng gần nhất
        const last9Months = getLast9Months();
        const fromInput = document.getElementById('fromElectricHidden');
        const toInput = document.getElementById('toElectricHidden');
        
        console.log('🔍 Found month hidden inputs:', fromInput, toInput);
        
        if (fromInput && toInput) {
          fromInput.value = last9Months[0].monthYear;
          toInput.value = last9Months[last9Months.length - 1].monthYear;
          
          console.log('📅 Set electric month range:', fromInput.value, 'to', toInput.value);
          
          // Recreate month range picker
          setTimeout(() => {
            if (pickerRoots.electricRange) {
