  // Hàm tạo danh sách ngày đầy đủ trong range
  function getDateRange(fromDate, toDate) {
    const dates = [];
    const start = new Date(fromDate);
    const end = new Date(toDate);
    
    // Không bao gồm ngày cuối (toDate), chỉ đến ngày trước đó
    for (let d = new Date(start); d < end; d.setDate(d.getDate() + 1)) {
      const day = String(d.getDate()).padStart(2, '0');
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const year = String(d.getFullYear()).slice(-2);
      dates.push(`${day}/${month}/${year}`);
    }
    return dates;
  }

  // Hàm đảm bảo dữ liệu đầy đủ cho tất cả ngày
  function ensureCompleteData(historyData, fromDate, toDate) {
    // Nếu không có fromDate hoặc toDate, sử dụng default (10 ngày gần nhất)
    if (!fromDate || !toDate) {
      const today = new Date();
      const tenDaysAgo = new Date(today);
      tenDaysAgo.setDate(today.getDate() - 9);
      
      fromDate = tenDaysAgo.toISOString().split('T')[0];
      toDate = today.toISOString().split('T')[0];
    }
    
    const completeDates = getDateRange(fromDate, toDate);
    const completeData = {};
    
    // Nếu server đã tính consumption thì sử dụng luôn
    // Nếu không thì client sẽ tính consumption
    if (Object.keys(historyData).length > 0) {
      // Server đã xử lý, chỉ cần fill missing dates với 0
      completeDates.forEach(date => {
        completeData[date] = historyData[date] || 0;
      });
    } else {
      // Fallback: client tự tính consumption nếu server không có data
      completeDates.forEach(date => {
        completeData[date] = 0;
      });
    }
    
    return completeData;
  }

