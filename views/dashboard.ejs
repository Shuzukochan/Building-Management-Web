    }
    
    .dropdown-node-details {
      font-size: 0.8em;
      color: #6b7280;
      font-family: monospace;
    }
    
    .dropdown-node-actions {
      display: flex;
      gap: 4px;
    }
    
    .btn-dropdown-delete {
      background: #fee2e2;
      border: none;
      color: #dc2626;
      padding: 4px 6px;
      border-radius: 4px;
