      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.8em;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 3px;
    }
    
    .btn-add-node:hover {
      background: #d1d5db;
      border-color: #6b7280;
      color: #374151;
    }
    
    /* Nodes dropdown summary */
    .nodes-summary {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    
    .nodes-count-badge {
      background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
