    .nodes-count-badge:hover {
      background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);
      transform: translateY(-1px);
      box-shadow: 0 4px 8px rgba(0,0,0,0.15);
    }
    
    .nodes-count-badge.no-nodes {
      background: #e5e7eb;
      color: #6b7280;
    }
    
    .nodes-count-badge.no-nodes:hover {
